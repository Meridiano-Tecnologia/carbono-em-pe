# ==========================================
# CARBONO EM PÉ — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha
# NUNCA commite o arquivo .env
# ==========================================

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Segurança JWT
JWT_SECRET_KEY=gere-uma-chave-forte-aqui
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Google Earth Engine
GEE_SERVICE_ACCOUNT=sua-conta-de-servico@projeto.iam.gserviceaccount.com
GEE_KEY_FILE=caminho/para/chave.json
GEE_PROJECT_ID=seu-projeto-gee

# NFE.io
NFEIO_API_KEY=sua-chave-nfeio
NFEIO_COMPANY_ID=seu-id-empresa

# E-mail
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_USER=seu-email@meridianotecnologia.com.br
SMTP_PASSWORD=sua-senha-smtp

# Aplicação
APP_ENV=development
APP_SECRET_KEY=gere-uma-chave-forte-aqui
APP_ALLOWED_ORIGINS=http://localhost:3000,https://meridianotecnologia.com.br
LOG_LEVEL=INFO

# Armazenamento Supabase
SUPABASE_STORAGE_BUCKET=carbono-em-pe-relatorios
